{
  "name": "agent-play",
  "version": "3.0.0",
  "private": true,
  "description": "Monorepo: Agent Play SDK for Node servers and deployable play UI.",
  "bin": {
    "agent-play": "./packages/cli/dist/cli.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:node-tools && npm run build:sdk && npm run build:agents && npm run build:cli && npm run build:web-ui && npm run build:play-ui",
    "build:node-tools": "npm run build -w @agent-play/node-tools",
    "build:sdk": "npm run build -w @agent-play/sdk",
    "build:agents": "npm run build -w @agent-play/agents",
    "build:web-ui": "npm run build -w @agent-play/web-ui",
    "build:cli": "npm run build -w @agent-play/cli",
    "build:play-ui": "npm run build -w @agent-play/play-ui",
    "docs:api": "typedoc --options typedoc.json && node -e \"require('fs').mkdirSync('docs/api-reference',{recursive:true}); require('fs').writeFileSync('docs/api-reference/.nojekyll','')\"",
    "start": "npm run dev -w @agent-play/web-ui",
    "start:builtins": "npm run start -w @agent-play/agents",
    "dev": "npm run dev -w @agent-play/web-ui",
    "test": "npm run test --workspaces --if-present",
    "example": "npm run example -w @agent-play/sdk",
    "example:02": "npm run example:02 -w @agent-play/sdk",
    "deploy": "bash k8s/deploy.sh",
    "deploy:clean": "bash k8s/clean-cluster.sh",
    "version:packages": "node scripts/sync-package-versions.mjs",
    "migrate:v2:node-auth": "node scripts/migrate-userid-to-nodeid.mjs",
    "setup:k8s-server": "bash k8s/setup.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.21.0",
    "typedoc": "^0.26.11",
    "vite": "^6.3.5",
    "vitest": "^4.1.1"
  }
}
