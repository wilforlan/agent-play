# =============================================================================
# Seed amenity content — Bravo Towers, SandMill Circle, My Plaza
# =============================================================================
#
# Space → amenity mapping (this file):
#
#   1. Bravo Towers      — car wash only (premium lot, slots 1–9)
#   2. SandMill Circle   — shop + supermarket (second unique inventory set)
#   3. My Plaza          — car wash + shop + supermarket (third unique set)
#
# How to run
# ----------
# 1. Open `/playground` and connect with your main passphrase (no CONNECT here).
# 2. Replace `<AGENT_SERVICE_KEY>` with the server's `AGENT_SERVICE_KEY` value.
# 3. Replace every <*_PASSPHRASE> with that space’s ten-word passphrase.
# 4. Paste the file and Run.
#
# Re-runs with the same SLOT / COLUMN values collide with existing rows; clear
# with REMOVE AMENITY ITEMS or adjust slots first if you are topping up.
#
# Prerequisites: each space already has the right amenities attached
# (`ADD AMENITY "shop"` / `"supermarket"` / `"car_wash"` if needed).
# =============================================================================

USE PLATFORM KEY "<AGENT_SERVICE_KEY>"

# =============================================================================
# 1. Bravo Towers — car wash (first lot: premium)
# =============================================================================

USE SPACE NODE "node:9728e8ed094690727a355be63f711dc3e40df3d068dccb3089bc96b7c338c966"
  PASSPHRASE "<BRAVO_TOWERS_PASSPHRASE>"

ADD CARWASH CAR SLOT 1 NAME "Phantom Coupe"   MODEL "Rolls XV"    YEAR 2024 PRICE 70.85 COLOR "#d4af37"
ADD CARWASH CAR SLOT 2 NAME "Continental GT"  MODEL "Bentley"     YEAR 2023 PRICE 24.50 COLOR "#1a2a4a"
ADD CARWASH CAR SLOT 3 NAME "S-Class Maybach" MODEL "Mercedes"    YEAR 2024 PRICE 90.15 COLOR "#0d0d0d"
ADD CARWASH CAR SLOT 4 NAME "911 Turbo S"     MODEL "Porsche"     YEAR 2024 PRICE 89.00 COLOR "#b80c1c"
ADD CARWASH CAR SLOT 5 NAME "Aventador"       MODEL "Lamborghini" YEAR 2022 PRICE 49.00 COLOR "#f7e600"
ADD CARWASH CAR SLOT 6 NAME "Ghibli Trofeo"   MODEL "Maserati"    YEAR 2023 PRICE 98.00 COLOR "#ecebe9"
ADD CARWASH CAR SLOT 7 NAME "Range Rover SV"  MODEL "Land Rover"  YEAR 2024 PRICE 95.00 COLOR "#224d33"
ADD CARWASH CAR SLOT 8 NAME "Model S Plaid"   MODEL "Tesla"       YEAR 2024 PRICE 35.00 COLOR "#61676c"
ADD CARWASH CAR SLOT 9 NAME "Cullinan"        MODEL "Rolls-Royce" YEAR 2024 PRICE 45.00 COLOR "#1c2540"

# =============================================================================
