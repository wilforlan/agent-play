  DESCRIPTION "Tiny changes, remarkable results" PRICE 18.50
ADD SHOP ITEM TYPE "book"   NAME "Clean Code"
  DESCRIPTION "Robert C. Martin — craftsmanship and readability" PRICE 32.99
ADD SHOP ITEM TYPE "book"   NAME "Structure and Interpretation of Computer Programs"
  DESCRIPTION "Abelson & Sussman — classic CS foundations" PRICE 44.00
ADD SHOP ITEM TYPE "book"   NAME "Working Effectively with Legacy Code"
  DESCRIPTION "Michael Feathers — safe refactoring strategies" PRICE 36.50
ADD SHOP ITEM TYPE "music"  NAME "Kind of Blue"
  DESCRIPTION "Miles Davis — modal jazz landmark" PRICE 14.99
ADD SHOP ITEM TYPE "music"  NAME "Random Access Memories"
  DESCRIPTION "Daft Punk — disco-funk masterpiece" PRICE 16.99
ADD SHOP ITEM TYPE "music"  NAME "OK Computer"
  DESCRIPTION "Radiohead — alt-rock classic" PRICE 15.50
ADD SHOP ITEM TYPE "coffee" NAME "Ethiopian Yirgacheffe"
  DESCRIPTION "Bright, floral, citrus notes" PRICE 18.00
ADD SHOP ITEM TYPE "coffee" NAME "Colombian Supremo"
  DESCRIPTION "Smooth, balanced, medium roast" PRICE 14.50

# ---- supermarket (full grid: row 1-4, ~4-5 items per row) ----

