# =============================================================================
# Seed amenity content for all spaces
# =============================================================================
#
# This is an AQL migration script that seeds the shop, supermarket and
# car-wash amenities across every space configured in the world:
#
#   1. Bravo Towers     — car wash
#   2. My Plaza         — car wash, shop, supermarket
#   3. SandMill Circle  — shop, supermarket
#   4. Apple Store      — shop, supermarket
#   5. Perraw Lane      — supermarket, car wash
#   6. Albert Crest     — supermarket
#   7. Nelson SPA       — shop, supermarket
#
# How to run
# ----------
# 1. Open the playground at `/playground` and connect with your main
#    passphrase. The playground session is reused by the script, so this
#    file does *not* include a `CONNECT` statement.
# 2. Replace `<AGENT_SERVICE_KEY>` below with the same value as the server's
#    `AGENT_SERVICE_KEY` env var (required for CREATE SPACE, ADD AMENITY, and
#    all content authoring when that env is set).
# 3. **Fresh world:** run Phase 0 below — it creates all seven spaces with
#    random owner names, attaches the required amenities, and captures each
#    space's `nodeId` + passphrase into `$bravoTowers`, `$myPlaza`, etc.
# 4. **Existing spaces:** comment out Phase 0 and uncomment the fallback
#    `USE SPACE NODE` line in each content section (with your real node id
#    and ten-word passphrase).
# 5. Paste this entire file into the editor and click Run.
#
# The script is safe to re-run for *new* slots — the server auto-assigns
# free supermarket columns and car-wash slots when omitted. Re-running
# with the same explicit SLOT/COLUMN values will collide; remove or adjust
# those rows if you need to top up.
#
# Notes
# -----
# - Phase 0 is idempotent only in the sense that re-running it creates *new*
#   spaces; do not re-run Phase 0 on a world that already has these venues.
# - Every player wallet starts at $70 automatically; nothing to seed there.
# =============================================================================

# =============================================================================
# Platform key (required when server AGENT_SERVICE_KEY is set)
# =============================================================================

USE PLATFORM KEY "<AGENT_SERVICE_KEY>"

# =============================================================================
# Phase 0 — Create spaces, attach amenities (comment out if spaces exist)
# =============================================================================

# 1. Bravo Towers — car wash
CREATE SPACE "Bravo Towers" DESIGN "car-wash-v1" OWNER "Marcus Holloway"
  DESCRIPTION "Premium tower car wash"
INTO bravoTowers
USE SPACE NODE $bravoTowers.nodeId PASSPHRASE $bravoTowers.phrase
ADD AMENITY "car_wash"

# 2. My Plaza — car wash + shop + supermarket
CREATE SPACE "My Plaza" DESIGN "supermarket-v1" OWNER "Priya Mehta"
  DESCRIPTION "Mixed-use neighborhood plaza"
INTO myPlaza
USE SPACE NODE $myPlaza.nodeId PASSPHRASE $myPlaza.phrase
ADD AMENITY "car_wash"
ADD AMENITY "shop"
ADD AMENITY "supermarket"

# 3. SandMill Circle — shop + supermarket
CREATE SPACE "SandMill Circle" DESIGN "shop-v1" OWNER "Elena Vasquez"
  DESCRIPTION "Artisan market circle"
INTO sandMillCircle
USE SPACE NODE $sandMillCircle.nodeId PASSPHRASE $sandMillCircle.phrase
ADD AMENITY "shop"
ADD AMENITY "supermarket"

# 4. Apple Store — shop + supermarket
CREATE SPACE "Apple Store" DESIGN "shop-v1" OWNER "Jordan Kim"
  DESCRIPTION "Flagship accessories and services"
INTO appleStore
USE SPACE NODE $appleStore.nodeId PASSPHRASE $appleStore.phrase
ADD AMENITY "shop"
ADD AMENITY "supermarket"

# 5. Perraw Lane — supermarket + car wash
CREATE SPACE "Perraw Lane" DESIGN "supermarket-v1" OWNER "Sofia Lindstrom"
  DESCRIPTION "Designer retail and prestige marques"
INTO perrawLane
USE SPACE NODE $perrawLane.nodeId PASSPHRASE $perrawLane.phrase
ADD AMENITY "supermarket"
ADD AMENITY "car_wash"

# 6. Albert Crest — supermarket
CREATE SPACE "Albert Crest" DESIGN "supermarket-v1" OWNER "David Okonkwo"
  DESCRIPTION "Global prestige care and apothecary"
INTO albertCrest
USE SPACE NODE $albertCrest.nodeId PASSPHRASE $albertCrest.phrase
ADD AMENITY "supermarket"

# 7. Nelson SPA — shop + supermarket
CREATE SPACE "Nelson SPA" DESIGN "shop-v1" OWNER "Amara Bennett"
  DESCRIPTION "Bath, body, treatment and gift lines"
INTO nelsonSpa
USE SPACE NODE $nelsonSpa.nodeId PASSPHRASE $nelsonSpa.phrase
ADD AMENITY "shop"
ADD AMENITY "supermarket"

# =============================================================================
# 1. Bravo Towers — car wash (premium lot; wash-tier prices, low to flagship)
