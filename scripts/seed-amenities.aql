# =============================================================================
# Seed amenity content for all spaces
# =============================================================================
#
# This is an AQL migration script that seeds the shop, supermarket and
# car-wash amenities across every space currently configured in the world:
#
#   1. Bravo Towers     — car wash
#   2. My Plaza         — car wash, shop, supermarket
#   3. SandMill Circle  — shop, supermarket
#
# How to run
# ----------
# 1. Open the playground at `/playground` and connect with your main
#    passphrase. The playground session is reused by the script, so this
#    file does *not* include a `CONNECT` statement.
# 2. Replace every <PASSPHRASE> placeholder with the matching space's
#    passphrase.
# 3. Paste this entire file into the editor and click Run.
#
# The script is safe to re-run for *new* slots — the server auto-assigns
# free supermarket columns and car-wash slots when omitted. Re-running
# with the same explicit SLOT/COLUMN values will collide; remove or adjust
# those rows if you need to top up.
#
# Pre-requisites
# --------------
# - Each space must already have its amenities attached (you said you do).
#   If not, run `ADD SPACE AMENITY "shop"` (etc.) for the active space
#   first.
# - Every player wallet starts at $70 automatically; nothing to seed there.
# =============================================================================

# =============================================================================
# 1. Bravo Towers — car wash (premium lot; wash-tier prices, low to flagship)
# =============================================================================

USE SPACE NODE "node:9728e8ed094690727a355be63f711dc3e40df3d068dccb3089bc96b7c338c966"
  PASSPHRASE "<BRAVO_TOWERS_PASSPHRASE>"

ADD CARWASH CAR SLOT 1 NAME "Phantom Coupe"   MODEL "Rolls XV"    YEAR 2024 PRICE 25.99  COLOR "#d4af37"
ADD CARWASH CAR SLOT 2 NAME "Continental GT"  MODEL "Bentley"     YEAR 2023 PRICE 35.50  COLOR "#1a2a4a"
ADD CARWASH CAR SLOT 3 NAME "S-Class Maybach" MODEL "Mercedes"    YEAR 2024 PRICE 44.00  COLOR "#0d0d0d"
ADD CARWASH CAR SLOT 4 NAME "911 Turbo S"     MODEL "Porsche"     YEAR 2024 PRICE 52.75  COLOR "#b80c1c"
ADD CARWASH CAR SLOT 5 NAME "Aventador"       MODEL "Lamborghini" YEAR 2022 PRICE 61.25  COLOR "#f7e600"
ADD CARWASH CAR SLOT 6 NAME "Ghibli Trofeo"   MODEL "Maserati"    YEAR 2023 PRICE 68.00  COLOR "#ecebe9"
ADD CARWASH CAR SLOT 7 NAME "Range Rover SV"  MODEL "Land Rover"  YEAR 2024 PRICE 76.50  COLOR "#224d33"
ADD CARWASH CAR SLOT 8 NAME "Model S Plaid"   MODEL "Tesla"       YEAR 2024 PRICE 87.99  COLOR "#61676c"
ADD CARWASH CAR SLOT 9 NAME "Cullinan"        MODEL "Rolls-Royce" YEAR 2024 PRICE 99.99  COLOR "#1c2540"

# =============================================================================
# 2. My Plaza — car wash + shop + supermarket (everyday mix)
# =============================================================================

USE SPACE NODE "node:6ae62056cee16358446278a7f69f3d2d81b18d16a3478fc15f69c75103482e91"
  PASSPHRASE "<MY_PLAZA_PASSPHRASE>"

# ---- car wash (mid-range, 6 cars; slots 7-9 left open) ----

ADD CARWASH CAR SLOT 1 NAME "Civic Type R" MODEL "Honda"  YEAR 2024 PRICE 48000 COLOR "#f8f9fa"
ADD CARWASH CAR SLOT 2 NAME "Mustang GT"   MODEL "Ford"   YEAR 2024 PRICE 52000 COLOR "#c91432"
ADD CARWASH CAR SLOT 3 NAME "Camry XSE"    MODEL "Toyota" YEAR 2024 PRICE 36500 COLOR "#1a1a1a"
ADD CARWASH CAR SLOT 4 NAME "Wrangler"     MODEL "Jeep"   YEAR 2024 PRICE 42000 COLOR "#5d6b3d"
ADD CARWASH CAR SLOT 5 NAME "Model 3"      MODEL "Tesla"  YEAR 2024 PRICE 42500 COLOR "#1f3a5f"
ADD CARWASH CAR SLOT 6 NAME "Outback"      MODEL "Subaru" YEAR 2024 PRICE 34500 COLOR "#4a6041"

# ---- shop (11 items: 6 books, 3 music, 2 coffee) ----

ADD SHOP ITEM TYPE "book"   NAME "The Pragmatic Programmer"
  DESCRIPTION "20th Anniversary Edition — Hunt & Thomas" PRICE 24.99
ADD SHOP ITEM TYPE "book"   NAME "Designing Data-Intensive Applications"
  DESCRIPTION "Reliable, scalable, maintainable systems" PRICE 39.99
