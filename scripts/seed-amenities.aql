ADD SUPERMARKET ITEM ROW 3 NAME "Scarf"       DESCRIPTION "Silk blend"            PRICE 26.00 COLUMN 4
ADD SUPERMARKET ITEM ROW 3 NAME "Sunglasses"  DESCRIPTION "UV400 polarized"       PRICE 38.00 COLUMN 5

# Row 4 - Kids
