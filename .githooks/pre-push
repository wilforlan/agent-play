#!/bin/sh
set -e
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

ZERO="0000000000000000000000000000000000000000"
has_pkg_in_push=0
any_ref=0

while read -r local_ref local_sha remote_ref remote_sha; do
  any_ref=1
  [ -z "$local_sha" ] && continue
  [ "$local_sha" = "$ZERO" ] && continue
  if [ "$remote_sha" = "$ZERO" ] || [ -z "$remote_sha" ]; then
    range="${ZERO}..${local_sha}"
  else
    range="${remote_sha}..${local_sha}"
  fi
  if git log "$range" --name-only --pretty=format: -- packages/ 2>/dev/null | grep -q '^packages/'; then
    has_pkg_in_push=1
    break
  fi
done

if [ "$any_ref" -eq 0 ]; then
  has_pkg_in_push=1
fi

if [ "$has_pkg_in_push" -eq 0 ]; then
  exit 0
fi

if [ -n "$(git status --porcelain -- packages/ 2>/dev/null)" ]; then
  echo "pre-push: uncommitted changes under packages/. Commit or stash before pushing." >&2
  exit 1
fi

VERSION=$(node -p "require('./package.json').version")

if node scripts/sync-package-versions.mjs --check 2>/dev/null; then
  exit 0
fi

node scripts/sync-package-versions.mjs "$VERSION"
echo "" >&2
echo "pre-push: package.json versions were out of sync; they are fixed locally." >&2
echo "pre-push: stage and commit, then push again:" >&2
echo "  git add package.json packages/sdk/package.json packages/cli/package.json packages/play-ui/package.json packages/web-ui/package.json" >&2
echo "  git commit -m \"chore: sync package versions\"" >&2
exit 1
