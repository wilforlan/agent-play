# Copy to .env.local (same directory). Do not commit secrets.
# cp .env.local.example .env.local

# --- HTTP server (packages/web-ui/server.ts) ---
# PORT=3000
# HOSTNAME=127.0.0.1
# NODE_ENV=development

# --- Redis: required for sessions, AgentRepository, SSE fanout across instances ---
# The web UI process refuses to start without REDIS_URL.
REDIS_URL=redis://127.0.0.1:6379

# --- Isolate keys when sharing one Redis across envs or tenants ---
# AGENT_PLAY_HOST_ID=default

# --- Base URL for session / preview links (override default in get-world) ---
# PLAY_PREVIEW_BASE_URL=http://127.0.0.1:3000

# --- Logging ---
# AGENT_PLAY_DEBUG=1
# AGENT_PLAY_VERBOSE=1

# --- Admin API (Bearer). Required in production if you use admin routes. ---
# AGENT_PLAY_ADMIN_TOKEN=replace-with-long-random-secret

# --- Browser-visible path prefix (Next injects these for the embedded bundle) ---
# NEXT_PUBLIC_AGENT_PLAY_BASE=/agent-play
# NEXT_PUBLIC_PLAY_API_BASE=/agent-play
# Split origin (UI and API on different hosts): set both to your public API path prefix, e.g.
# NEXT_PUBLIC_PLAY_API_BASE=https://api.example.com/agent-play

# --- Vite-only (packages/play-ui), if you build that package separately ---
# VITE_PLAY_API_BASE=https://your-api.example.com/agent-play
# VITE_APP_VERSION=0.0.0-local
# VITE_APP_REPO_URL=https://github.com/your-org/agent-play
