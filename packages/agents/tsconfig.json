{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@agent-play/node-tools": ["../node-tools/src/index.ts"],
      "@agent-play/sdk": ["../sdk/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
