{
  "name": "@agent-play/agents",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Reference LangChain agents for Agent Play (built-in world demos).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express-server": "./dist/express-server.js",
    "./src/*": "./src/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node ./scripts/copy-root.mjs",
    "prestart": "node ./scripts/copy-root.mjs",
    "copy-root": "node ./scripts/copy-root.mjs",
    "build": "tsup",
    "start": "node ./dist/express-server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@agent-play/node-tools": "^3.1.0",
    "@agent-play/sdk": "^3.1.0",
    "dotenv": "^17.3.1",
    "@langchain/openai": "^1.3.0",
    "express": "^4.21.2",
    "langchain": "^1.2.36",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.1"
  }
}
