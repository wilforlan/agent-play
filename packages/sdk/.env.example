# Copy to .env in this directory for SDK examples. Do not commit real keys.
# cp .env.example .env

# LangChain examples
# OPENAI_API_KEY=

# Target web UI (no trailing path required beyond origin; examples compose /api paths)
# AGENT_PLAY_WEB_UI_URL=http://127.0.0.1:3000

# Account API key from CLI (agent-play create-key) when Redis repository is enabled
# AGENT_PLAY_API_KEY=

# Required: how long the example holds the session open (seconds)
# AGENT_PLAY_HOLD_SECONDS=3600

# Required: bind to a specific registered agent id (example 01)
# AGENT_PLAY_AGENT_ID=

# Required: two-player example
# AGENT_PLAY_AGENT_ID_ALPHA=
# AGENT_PLAY_AGENT_ID_BETA=

# AGENT_PLAY_SERVER_URL=http://127.0.0.1:3000
