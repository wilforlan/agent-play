{
  "name": "@agent-play/sdk",
  "type": "module",
  "version": "0.0.1",
  "description": "Node.js SDK to register agents, stream world state, and mount the play preview API.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "examples"
  ],
  "author": "Isaac Williams",
  "license": "MIT",
  "private": false,
  "scripts": {
    "build": "echo \"SDK ships TypeScript sources; consumers bundle or compile.\"",
    "build:play-ui": "npm run build --prefix ../play-ui",
    "tsup": "tsup",
    "example": "tsx -r dotenv/config examples/01-langchain-minimal-invoke.ts",
    "example:02": "tsx -r dotenv/config examples/02-multi-tool-path.ts",
    "example:03": "tsx -r dotenv/config examples/03-two-agents-two-players.ts",
    "example:04": "tsx -r dotenv/config examples/04-env-and-preview-link.ts",
    "example:sse": "npx tsx -r examples/05-express-sse-bridge.ts",
    "example:production": "tsx examples/production-server.ts",
    "example:advisor": "tsx -r examples/06-financial-advisor-server.ts",
    "lint": "eslint src",
    "lint:fix": "npm run lint --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@langchain/core": "^1.1.35",
    "@langchain/openai": "^1.3.0",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "eventsource-client": "^1.2.0",
    "ioredis": "^5.6.0",
    "langchain": "^1.2.36",
    "node-fetch": "^3.3.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "uuidv4": "^6.2.13"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/supertest": "^6.0.3",
    "express": "^4.21.2",
    "supertest": "^7.1.4",
    "vitest": "^3.0.9"
  },
  "peerDependencies": {
    "express": "^4.21.0 || ^5.0.0"
  }
}
