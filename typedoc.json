{
  "$schema": "https://typedoc.org/schema.json",
  "name": "Agent Play API",
  "entryPoints": [
    "packages/sdk/src/index.ts",
    "packages/intercom/src/index.ts",
    "packages/cli/src/cli.ts"
  ],
  "entryPointStrategy": "resolve",
  "out": "docs/api-reference",
  "readme": "none",
  "excludePrivate": true,
  "excludeProtected": true,
  "compilerOptions": {
    "skipLibCheck": true
  }
}
